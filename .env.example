# Auth0 ETMS - Environment Variables
# Copy this to .env and fill in your Auth0 credentials

# ─── Auth0 Core ───────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://etms-api.example.com

# ─── Auth0 AI / Token Vault ──────────────────────────────────
AUTH0_AI_SECRET=your-auth0-ai-secret
AUTH0_CONNECTION_GOOGLE=google-oauth2
AUTH0_CONNECTION_SLACK=sign-in-with-slack

# ─── Auth0 Custom API (for M2M + Token Vault) ────────────────
AUTH0_CUSTOM_API_CLIENT_ID=your-custom-api-client-id
AUTH0_CUSTOM_API_CLIENT_SECRET=your-custom-api-client-secret
AUTH0_M2M_CLIENT_ID=your-m2m-client-id
AUTH0_M2M_CLIENT_SECRET=your-m2m-client-secret

# ─── Auth0 FGA (Fine-Grained Authorization) ──────────────────
FGA_STORE_ID=your-fga-store-id
FGA_API_URL=https://api.us1.fga.dev
FGA_CLIENT_ID=your-fga-client-id
FGA_CLIENT_SECRET=your-fga-client-secret

# ─── External Service Scopes (Token Vault managed) ───────────
GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar
SLACK_SCOPE=chat:write,channels:read

# ─── MQTT (existing infrastructure) ──────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883

# ─── OpenClaw API ────────────────────────────────────────────
OPENCLAW_API_URL=http://localhost:8080

# ─── Guardian Dashboard ─────────────────────────────────────
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-dashboard-client-id
NEXT_PUBLIC_AUTH0_CALLBACK_URL=http://localhost:3000/callback
